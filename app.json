{
  "expo": {
    "name": "savry",
    "slug": "savry-app",
    "version": "1.0.0",
    "newArchEnabled": false,
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#fdf9f2"
    },
    "scheme": "savry",
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.savry.app",
      "buildNumber": "1",
      "associatedDomains": [
        "applinks:savry.app"
      ],
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSCameraUsageDescription": "savry usa la cámara para fotografiar tus platos.",
        "NSPhotoLibraryUsageDescription": "savry accede a tus fotos para añadir imágenes a tus visitas.",
        "NSContactsUsageDescription": "savry usa tus contactos para encontrar amigos.",
        "NSLocationWhenInUseUsageDescription": "savry usa tu ubicación para encontrar restaurantes cercanos."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#fdf9f2"
      },
      "package": "com.savry.app",
      "versionCode": 1,
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "savry.app",
              "pathPrefix": "/invite"
            },
            {
              "scheme": "https",
              "host": "savry.app",
              "pathPrefix": "/u"
            },
            {
              "scheme": "https",
              "host": "savry.app",
              "pathPrefix": "/post"
            },
            {
              "scheme": "https",
              "host": "savry.app",
              "pathPrefix": "/r"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ],
      "permissions": [
        "android.permission.READ_CONTACTS",
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.RECEIVE_BOOT_COMPLETED",
        "android.permission.VIBRATE",
        "android.permission.RECORD_AUDIO",
        "android.permission.WRITE_CONTACTS"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      [
        "expo-image-picker",
        {
          "photosPermission": "savry necesita acceso a tus fotos para añadir imágenes a tus visitas.",
          "cameraPermission": "savry necesita acceso a la cámara para fotografiar tus platos."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#032417",
          "sounds": []
        }
      ],
      "expo-apple-authentication",
      [
        "expo-contacts",
        {
          "contactsPermission": "savry usa tus contactos para encontrar amigos que ya usan la app."
        }
      ],
      "@sentry/react-native"
    ],
    "extra": {
      "eas": {
        "projectId": "8a241d05-0e5e-4e38-8e41-43263c028886"
      },
      "router": {}
    },
    "owner": "jaimefdez",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/8a241d05-0e5e-4e38-8e41-43263c028886"
    }
  }
}
